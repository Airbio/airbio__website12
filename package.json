{
  "name": "airbio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview"
  },

  "reactSnap": {
    "source": "dist",
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage"
    ],
    "minifyHtml": true,
    "include": [
      "/",
      "/about",
      "/contact",
      "/blog",
      "/faq",
      "/product/Biosafety/BscClassIIB2",
      "/product/Biosafety/BscClassIIA2"
    ]
  }
}